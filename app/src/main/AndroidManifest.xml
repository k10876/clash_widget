<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Minimal permissions for widget functionality -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".ClashWidgetApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/WidgetTheme"
        tools:targetApi="34">

        <!-- Main Widget Provider -->
        <receiver
            android:name=".ClashWidgetProvider"
            android:exported="true"
            android:label="@string/widget_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.clashwidget.ACTION_TOGGLE" />
                <action android:name="com.clashwidget.ACTION_REFRESH" />
                <action android:name="com.clashwidget.ACTION_CUSTOM_COMMAND" />
                <action android:name="com.clashwidget.ACTION_CONFIGURATION_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

    </application>

</manifest>
